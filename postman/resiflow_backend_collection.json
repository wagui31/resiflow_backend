                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('userToken', json.token || '');",
                  "pm.environment.set('userId', json.userId || '');"
