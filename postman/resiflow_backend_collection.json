      "name": "90 - Scenarios",
      "item": [
        {
          "name": "Scenario 01 - Bootstrap Minimal",
          "description": "Ordre recommande : Health -> Public App Config -> Login Super Admin -> Create Residence -> Create Admin Logement -> Create User Logement -> Create Admin User -> Login Admin -> Register User -> Get Pending Users -> Approve User -> Login User."
        },
        {
          "name": "Scenario 02 - Paiement Mensuel",
          "description": "Ordre recommande : Login User -> Create My Paiement -> Login Admin -> Get Pending Paiements For Admin -> Validate Paiement -> Get My Payment Status -> Get Paiements By Utilisateur -> Get Residence Dashboard -> Get Residence Impayes."
        },
        {
          "name": "Scenario 03 - Depense Partagee",
          "description": "Ordre recommande : Create Categorie Depense -> Create Depense Partagee -> Approve Depense -> Login User -> Create My Depense Partage Paiement -> Login Admin -> Get Pending Paiements For Admin -> Validate Paiement -> Get Paiements By Depense -> Get Depense Contributions."
        },
        {
          "name": "Scenario 04 - Vote Complet",
          "description": "Ordre recommande : Login Admin -> Create Vote -> Login User -> Vote User -> Login Admin -> Get Vote Result -> Get Vote Details -> Close Vote -> Create Depense From Vote. Reopen/Delete servent surtout aux tests de regression."
        },
        {
          "name": "Scenario 05 - Logements Et Occupation",
          "description": "Ordre recommande : Create Residence -> Create plusieurs logements -> Register User -> Get Logement Occupancy -> Approve User -> Get Logement Occupancy -> Activate/Deactivate logement -> Get Logements By Residence."
        }
      ]
    }
