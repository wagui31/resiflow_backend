{"info":{"_postman_id":"4b1c4b4c-8d5d-4cc8-a389-c91845d3d2a1","name":"Resiflow Backend","description":"Routes canoniques du backend Resiflow. Aliases egalement exposes cote backend mais non dupliques ici: /auth, /residences, /users, /categories-depenses, /api/payments. Scenarios a tester: 1) Health -> Public config. 2) Register -> Pending users -> Approve user -> Login -> Me. 3) Login USER -> Create my payment -> My payment status -> User history. 4) Login ADMIN -> Create payment -> List residence payments -> Validate/Reject. 5) Login SUPER_ADMIN -> Create residence -> List -> Update -> Delete. 6) Login ADMIN -> Create category -> Create depense -> Approve/Reject -> Cagnotte. 7) Login ADMIN -> Create vote -> Voter -> Resultat -> Cloturer/Reouvrir -> Creer depense.","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{jwt}}","type":"string"}]},"item":[{"name":"Public","item":[{"name":"Health","request":{"auth":{"type":"noauth"},"method":"GET","url":"{{baseUrl}}/health"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('200',function(){pm.response.to.have.status(200);});","pm.test('OK',function(){pm.expect(pm.response.text()).to.eql('OK');});"]}}]},{"name":"Public App Config","request":{"auth":{"type":"noauth"},"method":"GET","url":"{{baseUrl}}/api/public/app-config"}}]},{"name":"Auth","item":[{"name":"Login","request":{"auth":{"type":"noauth"},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"{{userEmail}}\",\"password\":\"{{userPassword}}\"}"},"url":"{{baseUrl}}/api/auth/login"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.token)pm.environment.set('jwt',j.token);","if(j.userId)pm.environment.set('currentUserId',j.userId);","if(j.residenceId)pm.environment.set('residenceId',j.residenceId);","if(j.currency)pm.environment.set('currency',j.currency);","if(j.role)pm.environment.set('currentUserRole',j.role);"]}}]},{"name":"Register","request":{"auth":{"type":"noauth"},"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"X-Client-Platform","value":"{{clientPlatform}}"}],"body":{"mode":"raw","raw":"{\"email\":\"{{newUserEmail}}\",\"firstName\":\"Test\",\"lastName\":\"Resident\",\"password\":\"{{newUserPassword}}\",\"residenceCode\":\"{{residenceCode}}\",\"numeroImmeuble\":\"B\",\"codeLogement\":\"12A\",\"captchaToken\":\"{{captchaToken}}\"}"},"url":"{{baseUrl}}/api/auth/register"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('pendingUserId',j.id);","if(j.residenceId)pm.environment.set('residenceId',j.residenceId);"]}}]}]},{"name":"Residences","item":[{"name":"Create Residence","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Residence Demo\",\"address\":\"10 rue des Tests, Paris\",\"code\":\"{{newResidenceCode}}\",\"enabled\":true,\"montantMensuel\":{{monthlyAmount}},\"currency\":\"{{currency}}\"}"},"url":"{{baseUrl}}/api/residences"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('residenceId',j.id);","if(j.code)pm.environment.set('residenceCode',j.code);"]}}]},{"name":"List Residences","request":{"method":"GET","url":"{{baseUrl}}/api/residences"}},{"name":"Residence Dashboard","request":{"method":"GET","url":"{{baseUrl}}/api/residences/{{residenceId}}/dashboard"}},{"name":"Residence Impayes","request":{"method":"GET","url":"{{baseUrl}}/api/residences/{{residenceId}}/impayes"}},{"name":"Residence Stats","request":{"method":"GET","url":"{{baseUrl}}/api/residences/{{residenceId}}/stats"}},{"name":"Update Residence","request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Residence Demo Updated\",\"address\":\"12 rue des Tests, Paris\",\"code\":\"{{residenceCode}}\",\"enabled\":true,\"montantMensuel\":{{monthlyAmount}},\"currency\":\"{{currency}}\"}"},"url":"{{baseUrl}}/api/residences/{{residenceId}}"}},{"name":"Delete Residence","request":{"method":"DELETE","url":"{{baseUrl}}/api/residences/{{residenceId}}"}}]},{"name":"Users","item":[{"name":"Create Admin","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"email\":\"{{createdAdminEmail}}\",\"firstName\":\"Admin\",\"lastName\":\"Created\",\"password\":\"{{createdAdminPassword}}\",\"residenceId\":{{residenceId}}}"},"url":"{{baseUrl}}/api/users/admin"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('adminUserId',j.id);"]}}]},{"name":"List Users","request":{"method":"GET","url":"{{baseUrl}}/api/users"}},{"name":"Current User","request":{"method":"GET","url":"{{baseUrl}}/api/users/me"}},{"name":"User Paiement History","request":{"method":"GET","url":"{{baseUrl}}/api/users/{{currentUserId}}/paiements"}},{"name":"Pending Users","request":{"method":"GET","url":"{{baseUrl}}/api/admin/users/pending"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(Array.isArray(j)&&j.length&&j[0].id)pm.environment.set('pendingUserId',j[0].id);"]}}]},{"name":"Approve User","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"comment\":\"Validation depuis Postman\"}"},"url":"{{baseUrl}}/api/admin/users/{{pendingUserId}}/approve"}},{"name":"Reject User","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"comment\":\"Refus depuis Postman\"}"},"url":"{{baseUrl}}/api/admin/users/{{pendingUserId}}/reject"}},{"name":"Update Residence Entry Date","request":{"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"dateEntreeResidence\":\"2026-01-15\"}"},"url":"{{baseUrl}}/api/admin/users/{{pendingUserId}}/date-entree-residence"}}]},{"name":"Paiements","item":[{"name":"Create Paiement","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"utilisateurId\":{{targetUserId}},\"residenceId\":{{residenceId}},\"nombreMois\":3,\"dateDebut\":\"2026-01-01\"}"},"url":"{{baseUrl}}/api/paiements"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('paymentId',j.id);"]}}]},{"name":"Create My Paiement","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"nombreMois\":2,\"dateDebut\":\"2026-04-01\"}"},"url":"{{baseUrl}}/api/payments/me"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('myPaymentId',j.id);"]}}]},{"name":"Paiements By User","request":{"method":"GET","url":"{{baseUrl}}/api/paiements/utilisateur/{{targetUserId}}"}},{"name":"Paiements By Residence","request":{"method":"GET","url":"{{baseUrl}}/api/paiements/residence/{{residenceId}}"}},{"name":"Validate Paiement","request":{"method":"PUT","url":"{{baseUrl}}/api/paiements/{{paymentId}}/validate"}},{"name":"Reject Paiement","request":{"method":"PUT","url":"{{baseUrl}}/api/paiements/{{paymentId}}/reject"}},{"name":"Delete Pending Paiement","request":{"method":"DELETE","url":"{{baseUrl}}/api/paiements/{{paymentId}}"}},{"name":"My Payment Status","request":{"method":"GET","url":"{{baseUrl}}/api/payments/me/status"}}]},{"name":"Categories et Depenses","item":[{"name":"Get Categories","request":{"method":"GET","url":"{{baseUrl}}/api/categories-depenses"}},{"name":"Create Category","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"nom\":\"Entretien immeuble\"}"},"url":"{{baseUrl}}/api/categories-depenses"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('categoryId',j.id);"]}}]},{"name":"Create Depense","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"residenceId\":{{residenceId}},\"categorieId\":{{categoryId}},\"montant\":250.50,\"description\":\"Remplacement ampoules hall\"}"},"url":"{{baseUrl}}/api/depenses"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('depenseId',j.id);"]}}]},{"name":"Approve Depense","request":{"method":"POST","url":"{{baseUrl}}/api/depenses/{{depenseId}}/approuver"}},{"name":"Reject Depense","request":{"method":"POST","url":"{{baseUrl}}/api/depenses/{{depenseId}}/rejeter"}},{"name":"Depenses By Residence","request":{"method":"GET","url":"{{baseUrl}}/api/depenses/residence/{{residenceId}}"}}]},{"name":"Cagnotte","item":[{"name":"Solde","request":{"method":"GET","url":"{{baseUrl}}/api/cagnotte/{{residenceId}}/solde"}},{"name":"Transactions","request":{"method":"GET","url":"{{baseUrl}}/api/cagnotte/{{residenceId}}/transactions"}}]},{"name":"Votes","item":[{"name":"Create Vote","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"residenceId\":{{residenceId}},\"titre\":\"Refection peinture hall\",\"description\":\"Valider une depense pour repeindre le hall principal\",\"montantEstime\":950.00,\"dateDebut\":\"2026-04-02T09:00:00\",\"dateFin\":\"2026-04-09T18:00:00\"}"},"url":"{{baseUrl}}/api/votes"},"event":[{"listen":"test","script":{"type":"text/javascript","exec":["var j=pm.response.json();","if(j.id)pm.environment.set('voteId',j.id);"]}}]},{"name":"Votes By Residence","request":{"method":"GET","url":"{{baseUrl}}/api/votes/residence/{{residenceId}}"}},{"name":"Get Vote","request":{"method":"GET","url":"{{baseUrl}}/api/votes/{{voteId}}"}},{"name":"Close Vote","request":{"method":"POST","url":"{{baseUrl}}/api/votes/{{voteId}}/cloturer"}},{"name":"Reopen Vote","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"nouvelleDateFin\":\"2026-04-12T18:00:00\",\"commentaire\":\"Prolongation de 3 jours\"}"},"url":"{{baseUrl}}/api/votes/{{voteId}}/reouvrir"}},{"name":"Delete Vote","request":{"method":"DELETE","url":"{{baseUrl}}/api/votes/{{voteId}}"}},{"name":"Remove User Vote","request":{"method":"DELETE","url":"{{baseUrl}}/api/votes/{{voteId}}/utilisateurs/{{targetUserId}}"}},{"name":"Voter","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"choix\":\"POUR\",\"commentaire\":\"Budget raisonnable\"}"},"url":"{{baseUrl}}/api/votes/{{voteId}}/voter"}},{"name":"Vote Result","request":{"method":"GET","url":"{{baseUrl}}/api/votes/{{voteId}}/resultat"}},{"name":"Vote Details","request":{"method":"GET","url":"{{baseUrl}}/api/votes/{{voteId}}/details"}},{"name":"Create Depense From Vote","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"montant\":920.00,\"commentaire\":\"Montant final negocie\"}"},"url":"{{baseUrl}}/api/votes/{{voteId}}/creer-depense"}}]}]}
